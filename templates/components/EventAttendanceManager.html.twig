{# LiveComponent — gestion des présences à un événement #}
<div {{ attributes }}>
    {% set participantIds = this.participantIds %}
    {% set planets = this.planets %}

    <style>
        .atm-toolbar {
            display: flex;
            align-items: center;
            gap: 1rem;
            margin-bottom: 1rem;
        }
        .atm-toolbar .input-wrap {
            flex: 1;
            position: relative;
            max-width: 380px;
        }
        .atm-toolbar .input-wrap svg {
            position: absolute;
            left: 0.75rem;
            top: 50%;
            transform: translateY(-50%);
            color: var(--text-subtle);
            pointer-events: none;
        }
        .atm-toolbar .input-wrap input {
            padding-left: 2.25rem;
        }
        .atm-counter {
            font-family: var(--font-mono);
            font-size: 0.8rem;
            color: var(--text-muted);
            white-space: nowrap;
        }
        .atm-counter strong {
            color: var(--green-bright);
            font-size: 1rem;
        }

        /* ── Filtres planètes ── */
        .atm-planet-filters {
            display: flex;
            flex-wrap: wrap;
            gap: 0.375rem;
            margin-bottom: 1.25rem;
            padding-bottom: 1rem;
            border-bottom: 1px solid var(--border);
        }
        .atm-pf-btn {
            display: inline-flex;
            align-items: center;
            gap: 0.375rem;
            padding: 0.25rem 0.75rem;
            font-family: var(--font-mono);
            font-size: 0.6rem;
            font-weight: 600;
            letter-spacing: 1.5px;
            text-transform: uppercase;
            border: 1px solid;
            cursor: pointer;
            background: transparent;
            transition: background 0.1s, border-color 0.1s, color 0.1s;
        }
        .atm-pf-btn img {
            width: 14px;
            height: 14px;
            object-fit: contain;
        }

        .atm-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(88px, 1fr));
            gap: 0.5rem;
        }

        .atm-card {
            background: var(--panel);
            border: 1px solid var(--border);
            padding: 0.625rem 0.5rem 0.5rem;
            cursor: pointer;
            text-align: center;
            transition: border-color 0.12s, background 0.12s, box-shadow 0.12s;
            position: relative;
            overflow: hidden;
            user-select: none;
            -webkit-user-select: none;
        }
        .atm-card:hover {
            border-color: var(--border-hover);
            background: var(--panel-raised);
        }
        .atm-card.is-present {
            border-color: rgba(102, 187, 106, 0.4);
            background: rgba(46, 125, 50, 0.12);
        }
        .atm-card.is-present:hover {
            border-color: rgba(102, 187, 106, 0.65);
            background: rgba(46, 125, 50, 0.18);
        }
        .atm-card.atm-hidden {
            display: none;
        }

        /* Barre de statut en haut de la carte */
        .atm-card::before {
            content: '';
            position: absolute;
            top: 0; left: 0; right: 0;
            height: 2px;
            background: transparent;
            transition: background 0.12s;
        }
        .atm-card.is-present::before {
            background: var(--green-bright);
            box-shadow: 0 0 6px var(--green-bright);
        }

        .atm-avatar {
            width: 44px;
            height: 44px;
            border-radius: 50%;
            overflow: hidden;
            margin: 0 auto 0.5rem;
            border: 1.5px solid var(--border);
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: var(--font-mono);
            font-size: 0.75rem;
            font-weight: 700;
            color: var(--text-muted);
            background: var(--bg);
            transition: border-color 0.12s;
        }
        .atm-card.is-present .atm-avatar {
            border-color: rgba(102, 187, 106, 0.5);
        }
        .atm-avatar img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        /* Logo planète en haut à gauche de la carte */
        .atm-planet {
            position: absolute;
            top: 4px;
            left: 4px;
            width: 16px;
            height: 16px;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .atm-planet img {
            width: 100%;
            height: 100%;
            object-fit: contain;
        }

        /* Coche verte — haut à droite de la carte, z-index max */
        .atm-check {
            position: absolute;
            top: 4px;
            right: 4px;
            width: 16px;
            height: 16px;
            background: var(--green-bright);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 9px;
            color: #000;
            font-weight: 900;
            opacity: 0;
            transform: scale(0);
            transition: opacity 0.12s, transform 0.12s;
            border: 1.5px solid var(--panel);
            z-index: 10;
        }
        .atm-card.is-present .atm-check {
            opacity: 1;
            transform: scale(1);
        }

        .atm-name {
            font-family: var(--font-mono);
            font-size: 0.65rem;
            color: var(--text);
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            line-height: 1.3;
            transition: color 0.12s;
        }
        .atm-card.is-present .atm-name {
            color: var(--green-bright);
        }
        .atm-lastname {
            font-family: var(--font-mono);
            font-size: 0.6rem;
            color: var(--text-subtle);
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            line-height: 1.3;
        }

        .atm-empty {
            grid-column: 1 / -1;
            text-align: center;
            padding: 3rem 1rem;
            color: var(--text-subtle);
            font-family: var(--font-mono);
            font-size: 0.8rem;
        }
    </style>

    <div class="atm-toolbar">
        <div class="input-wrap">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
            </svg>
            <input
                type="search"
                data-model="search"
                placeholder="Rechercher un astronaute…"
                class="input"
                autocomplete="off"
            >
        </div>
        <div class="atm-counter">
            <strong>{{ participantIds|length }}</strong> présent{{ participantIds|length > 1 ? 's' : '' }}
        </div>
        <button
            type="button"
            class="btn btn-ghost btn-sm"
            data-action="live#action"
            data-live-action-param="sendToSlack"
            style="display: inline-flex; align-items: center; gap: 0.4rem; white-space: nowrap;"
        >
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" style="flex-shrink:0;">
                <path d="M5.042 15.165a2.528 2.528 0 0 1-2.52 2.523A2.528 2.528 0 0 1 0 15.165a2.527 2.527 0 0 1 2.522-2.52h2.52v2.52zM6.313 15.165a2.527 2.527 0 0 1 2.521-2.52 2.527 2.527 0 0 1 2.521 2.52v6.313A2.528 2.528 0 0 1 8.834 24a2.528 2.528 0 0 1-2.521-2.522v-6.313zM8.834 5.042a2.528 2.528 0 0 1-2.521-2.52A2.528 2.528 0 0 1 8.834 0a2.528 2.528 0 0 1 2.521 2.522v2.52H8.834zM8.834 6.313a2.528 2.528 0 0 1 2.521 2.521 2.528 2.528 0 0 1-2.521 2.521H2.522A2.528 2.528 0 0 1 0 8.834a2.528 2.528 0 0 1 2.522-2.521h6.312zM18.956 8.834a2.528 2.528 0 0 1 2.522-2.521A2.528 2.528 0 0 1 24 8.834a2.528 2.528 0 0 1-2.522 2.521h-2.522V8.834zM17.688 8.834a2.528 2.528 0 0 1-2.523 2.521 2.527 2.527 0 0 1-2.52-2.521V2.522A2.527 2.527 0 0 1 15.165 0a2.528 2.528 0 0 1 2.523 2.522v6.312zM15.165 18.956a2.528 2.528 0 0 1 2.523 2.522A2.528 2.528 0 0 1 15.165 24a2.527 2.527 0 0 1-2.52-2.522v-2.522h2.52zM15.165 17.688a2.527 2.527 0 0 1-2.52-2.523 2.526 2.526 0 0 1 2.52-2.52h6.313A2.527 2.527 0 0 1 24 15.165a2.528 2.528 0 0 1-2.522 2.523h-6.313z"/>
            </svg>
            Envoyer sur Slack
        </button>
    </div>

    {# Filtres planètes — gérés en JS #}
    <div class="atm-planet-filters" id="atm-planet-filters">
        <button type="button" class="atm-pf-btn atm-pf-active"
                data-planet-filter=""
                style="border-color: var(--red); color: var(--red); background: var(--red-faint);">
            TOUTES
        </button>
        {% for planet in planets %}
            <button type="button" class="atm-pf-btn"
                    data-planet-filter="{{ planet.id }}"
                    data-planet-color="{{ planet.color }}"
                    style="border-color: {{ planet.color }}40; color: {{ planet.color }}99;">
                {% if planet.photo %}
                    <img src="/uploads/{{ planet.photo }}" alt="">
                {% endif %}
                {{ planet.name|upper }}
            </button>
        {% endfor %}
    </div>

    <div class="atm-grid" id="atm-grid">
        {% for astronaut in this.filteredAstronauts %}
            {% set isPresent = astronaut.id in participantIds %}
            <button
                type="button"
                class="atm-card{{ isPresent ? ' is-present' : '' }}"
                data-action="live#action"
                data-live-action-param="toggleParticipant"
                data-live-astronaut-id-param="{{ astronaut.id }}"
                data-planet-id="{{ astronaut.planet ? astronaut.planet.id : '' }}"
                title="{{ astronaut.firstName }} {{ astronaut.lastName }}"
            >
                {% if astronaut.planet and astronaut.planet.photo %}
                    <span class="atm-planet">
                        <img src="/uploads/{{ astronaut.planet.photo }}" alt="{{ astronaut.planet.name }}">
                    </span>
                {% endif %}
                <span class="atm-check">✓</span>
                <div class="atm-avatar">
                    {% if astronaut.photo %}
                        <img src="/uploads/{{ astronaut.photo }}" alt="{{ astronaut.firstName }}">
                    {% else %}
                        {{ astronaut.firstName|first }}{{ astronaut.lastName|first }}
                    {% endif %}
                </div>
                <div class="atm-name">{{ astronaut.firstName }}</div>
                <div class="atm-lastname">{{ astronaut.lastName }}</div>
            </button>
        {% else %}
            <div class="atm-empty">
                Aucun astronaute trouvé pour "{{ search }}".
            </div>
        {% endfor %}
    </div>

    <script>
    (function () {
        let activePlanet = '';

        function applyPlanetFilter() {
            document.querySelectorAll('#atm-grid .atm-card').forEach(card => {
                const match = activePlanet === '' || card.dataset.planetId === activePlanet;
                card.classList.toggle('atm-hidden', !match);
            });
        }

        function bindFilterButtons() {
            document.querySelectorAll('#atm-planet-filters .atm-pf-btn').forEach(btn => {
                btn.addEventListener('click', () => {
                    activePlanet = btn.dataset.planetFilter;

                    document.querySelectorAll('#atm-planet-filters .atm-pf-btn').forEach(b => {
                        const color = b.dataset.planetColor;
                        if (b === btn) {
                            b.classList.add('atm-pf-active');
                            if (color) {
                                b.style.background   = color + '18';
                                b.style.borderColor  = color;
                                b.style.color        = color;
                            } else {
                                b.style.background   = 'var(--red-faint)';
                                b.style.borderColor  = 'var(--red)';
                                b.style.color        = 'var(--red)';
                            }
                        } else {
                            b.classList.remove('atm-pf-active');
                            if (color) {
                                b.style.background  = 'transparent';
                                b.style.borderColor = color + '40';
                                b.style.color       = color + '99';
                            } else {
                                b.style.background  = 'transparent';
                                b.style.borderColor = 'var(--border)';
                                b.style.color       = 'var(--text-muted)';
                            }
                        }
                    });

                    applyPlanetFilter();
                });
            });
        }

        // Réapplique le filtre après chaque re-render du LiveComponent
        const root = document.querySelector('[data-controller="live"]');
        if (root) {
            root.addEventListener('live:render', () => applyPlanetFilter());
        }

        bindFilterButtons();
    })();
    </script>
</div>
