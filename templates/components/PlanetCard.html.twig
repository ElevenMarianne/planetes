<a href="{{ path('front_planets_show', {slug: planet.slug}) }}"
   class="card card-hover"
   style="padding: 1.5rem; display: block; border-color: {{ planet.color }}30; position: relative; overflow: hidden;">

    {# Glow background #}
    <div style="position: absolute; top: -30px; right: -30px; width: 120px; height: 120px; border-radius: 50%;
                background: {{ planet.color }}; filter: blur(40px); opacity: 0.12; pointer-events: none;"></div>

    <div style="display: flex; align-items: center; gap: 1rem; margin-bottom: 1rem; position: relative;">
        {% if planet.photo %}
            <img src="/uploads/{{ planet.photo }}" alt="{{ planet.name }}"
                 style="width: 3.5rem; height: 3.5rem; object-fit: contain; flex-shrink: 0;
                        filter: drop-shadow(0 0 10px {{ planet.color }}80);">
        {% else %}
            <div class="planet-orb" style="width: 3.5rem; height: 3.5rem; background-color: {{ planet.color }};
                 box-shadow: 0 0 16px {{ planet.color }}50; flex-shrink: 0;"></div>
        {% endif %}
        <h3 style="font-family: var(--font-display); font-weight: 800; font-size: 1.125rem; letter-spacing: -0.02em;
                   color: {{ planet.color }}; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
            {{ planet.name }}
        </h3>
    </div>

    {% if seasonPoints %}
        <div style="font-family: var(--font-display); font-weight: 800; font-size: 1.75rem; color: var(--text); line-height: 1; margin-bottom: 0.375rem;">
            {{ seasonPoints.totalPoints }}
            <span class="text-subtle" style="font-size: 0.875rem; font-weight: 400;">pts</span>
        </div>
    {% endif %}

    {% if planet.mantra %}
        <p class="text-subtle" style="font-size: 0.8rem; font-style: italic; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
            {{ planet.mantra }}
        </p>
    {% endif %}

</a>
