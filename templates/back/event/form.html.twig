{% extends 'base.html.twig' %}

{% block title %}Nouvel événement — Back-office{% endblock %}

{% block body %}
<div style="max-width: 520px; margin: 0 auto;">

    <div style="margin-bottom: 2rem;">
        <div class="header-tags">
            <span class="h-tag red">BACK-OFFICE</span>
            <span class="h-tag">ÉVÉNEMENTS</span>
        </div>
        <p class="page-title">NOUVEL ÉVÉNEMENT</p>
    </div>

    <form method="post" style="display: flex; flex-direction: column; gap: 1.25rem;">
        <div class="card" style="padding: 2rem; display: flex; flex-direction: column; gap: 1.25rem;">

            <div>
                <label style="display:block; font-family:var(--font-mono); font-size:0.6875rem; letter-spacing:2px; color:var(--text-muted); text-transform:uppercase; margin-bottom:0.375rem;">Nom de l'événement</label>
                <input type="text" name="name" required class="input">
            </div>

            <div>
                <label style="display:block; font-family:var(--font-mono); font-size:0.6875rem; letter-spacing:2px; color:var(--text-muted); text-transform:uppercase; margin-bottom:0.375rem;">Date et heure</label>
                <input type="datetime-local" name="date" required class="input">
            </div>

            <div>
                <label style="display:block; font-family:var(--font-mono); font-size:0.6875rem; letter-spacing:2px; color:var(--text-muted); text-transform:uppercase; margin-bottom:0.375rem;">Description</label>
                <textarea name="description" rows="3" class="input" style="resize: vertical;"></textarea>
            </div>

        </div>

        <div style="padding: 0.875rem 1rem; border: 1px solid var(--border);
                    background: var(--panel-raised); border-left: 3px solid var(--border);">
            <span style="font-family: var(--font-mono); font-size: 0.7rem; color: var(--text-subtle); letter-spacing: 1px;">
                Les événements ne génèrent pas de points — ils servent uniquement au suivi des présences.
            </span>
        </div>

        <div style="display: flex; gap: 0.75rem;">
            <button type="submit" class="btn btn-primary">CRÉER ET GÉRER LES PRÉSENCES</button>
            <a href="{{ path('back_events_index') }}" class="btn btn-ghost">ANNULER</a>
        </div>
    </form>
</div>
{% endblock %}
