{% extends 'base.html.twig' %}

{% block title %}Trophées — Back-office{% endblock %}

{% block body %}

<div style="display: flex; align-items: flex-end; justify-content: space-between; margin-bottom: 1.5rem;">
    <div>
        <div class="header-tags">
            <span class="h-tag red">BACK-OFFICE</span>
            <span class="h-tag amber">{{ trophies|length }} DISTINCTIONS</span>
        </div>
        <p class="page-title">TROPHÉES</p>
    </div>
    <div style="display: flex; gap: 0.75rem;">
        <a href="{{ path('back_dashboard') }}" class="btn btn-ghost btn-sm">← TABLEAU DE BORD</a>
        <a href="{{ path('back_trophies_award') }}" class="btn btn-ghost btn-sm">ATTRIBUER</a>
        <a href="{{ path('back_trophies_new') }}" class="btn btn-primary btn-sm">+ NOUVEAU</a>
    </div>
</div>

<div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 1px;
            border: 1px solid var(--border); background: var(--border);">
    {% for trophy in trophies %}
        <div style="background: var(--panel); padding: 1.25rem; display: flex; align-items: flex-start; gap: 1rem;">
            {% if trophy.image %}
                <img src="/uploads/{{ trophy.image }}" alt="{{ trophy.name }}"
                     style="width: 3.5rem; height: 3.5rem; object-fit: contain; flex-shrink: 0;
                            filter: drop-shadow(0 2px 6px rgba(255,214,0,0.3));">
            {% else %}
                <div style="width: 3.5rem; height: 3.5rem; flex-shrink: 0; background: var(--panel-raised);
                            border: 1px solid var(--border); display: flex; align-items: center;
                            justify-content: center; font-size: 1.5rem;">🏆</div>
            {% endif %}
            <div style="flex: 1; min-width: 0;">
                <div style="font-family: var(--font-display); font-size: 1rem; letter-spacing: 2px;
                            color: var(--gold); margin-bottom: 0.25rem;">{{ trophy.name|upper }}</div>
                {% if trophy.description %}
                    <p style="font-family: var(--font-mono); font-size: 0.65rem; color: var(--text-subtle);
                               letter-spacing: 1px; margin-bottom: 0.5rem; line-height: 1.5;
                               overflow: hidden; text-overflow: ellipsis; display: -webkit-box;
                               -webkit-line-clamp: 2; -webkit-box-orient: vertical;">{{ trophy.description }}</p>
                {% endif %}
                <div style="font-family: var(--font-mono); font-size: 0.6rem; color: var(--text-subtle); letter-spacing: 1px;">
                    {{ trophy.astronautTrophies|length }} ASTRONAUTE(S) · {{ trophy.planetTrophies|length }} PLANÈTE(S)
                </div>
            </div>
            <div style="display: flex; flex-direction: column; gap: 0.375rem; flex-shrink: 0;">
                <a href="{{ path('back_trophies_edit', {id: trophy.id}) }}" class="btn btn-ghost btn-sm">MODIFIER</a>
                <form method="post" action="{{ path('back_trophies_delete', {id: trophy.id}) }}"
                      data-controller="confirm-delete"
                      data-confirm-delete-message-value="Supprimer ce trophée ?">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete_trophy_' ~ trophy.id) }}">
                    <button type="submit" class="btn btn-sm" style="width: 100%; color: var(--red); border-color: var(--red-faint);">SUPPRIMER</button>
                </form>
            </div>
        </div>
    {% else %}
        <div style="grid-column: 1/-1; text-align: center; padding: 4rem; background: var(--panel); color: var(--text-subtle);
                    font-family: var(--font-mono); font-size: 0.75rem; letter-spacing: 3px;">
            AUCUN TROPHÉE CRÉÉ
        </div>
    {% endfor %}
</div>

{% endblock %}
