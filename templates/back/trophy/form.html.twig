{% extends 'base.html.twig' %}

{% block title %}{{ isEdit ? 'Modifier' : 'Nouveau' }} trophée — Back-office{% endblock %}

{% block body %}
<div style="max-width: 520px; margin: 0 auto;">

    <div style="margin-bottom: 2rem;">
        <div class="header-tags">
            <span class="h-tag red">BACK-OFFICE</span>
            <span class="h-tag">TROPHÉES</span>
        </div>
        <p class="page-title">{{ isEdit ? 'MODIFIER ' ~ trophy.name|upper : 'NOUVEAU TROPHÉE' }}</p>
    </div>

    <form method="post" enctype="multipart/form-data" style="display: flex; flex-direction: column; gap: 1.25rem;">
        <div class="card" style="padding: 2rem; display: flex; flex-direction: column; gap: 1.25rem;">

            <div>
                <label style="display:block; font-family:var(--font-mono); font-size:0.6875rem; letter-spacing:2px; color:var(--text-muted); text-transform:uppercase; margin-bottom:0.375rem;">Nom</label>
                <input type="text" name="name" value="{{ trophy.name }}" required class="input">
            </div>

            <div>
                <label style="display:block; font-family:var(--font-mono); font-size:0.6875rem; letter-spacing:2px; color:var(--text-muted); text-transform:uppercase; margin-bottom:0.375rem;">Description</label>
                <textarea name="description" rows="3" class="input" style="resize: vertical;"
                          placeholder="Description du trophée...">{{ trophy.description }}</textarea>
            </div>

            <div>
                <label style="display:block; font-family:var(--font-mono); font-size:0.6875rem; letter-spacing:2px; color:var(--text-muted); text-transform:uppercase; margin-bottom:0.375rem;">Image</label>
                {% if trophy.image %}
                    <div style="margin-bottom: 0.75rem;">
                        <img src="/uploads/{{ trophy.image }}" alt="{{ trophy.name }}"
                             style="width: 4rem; height: 4rem; object-fit: contain;
                                    filter: drop-shadow(0 2px 6px rgba(255,214,0,0.3));">
                    </div>
                {% endif %}
                <input type="file" name="image" accept="image/*" class="input" style="padding: 0.375rem;">
            </div>

        </div>

        <div style="display: flex; gap: 0.75rem;">
            <button type="submit" class="btn btn-primary">{{ isEdit ? 'METTRE À JOUR' : 'CRÉER LE TROPHÉE' }}</button>
            <a href="{{ path('back_trophies_index') }}" class="btn btn-ghost">ANNULER</a>
        </div>
    </form>
</div>
{% endblock %}
