{% extends 'base.html.twig' %}

{% block title %}Attribuer un trophée — Back-office{% endblock %}

{% block body %}
<div style="max-width: 560px; margin: 0 auto;">

    <div style="margin-bottom: 2rem;">
        <div class="header-tags">
            <span class="h-tag red">BACK-OFFICE</span>
            <span class="h-tag">TROPHÉES</span>
        </div>
        <p class="page-title">ATTRIBUER UN TROPHÉE</p>
    </div>

    <form method="post" style="display: flex; flex-direction: column; gap: 1.25rem;" id="award-form">
        <div class="card" style="padding: 2rem; display: flex; flex-direction: column; gap: 1.5rem;">

            <div>
                <label style="display:block; font-family:var(--font-mono); font-size:0.6875rem; letter-spacing:2px; color:var(--text-muted); text-transform:uppercase; margin-bottom:0.375rem;">Trophée</label>
                <select name="trophy" required class="input">
                    <option value="">— Sélectionner un trophée —</option>
                    {% for trophy in trophies %}
                        <option value="{{ trophy.id }}">{{ trophy.name }}</option>
                    {% endfor %}
                </select>
            </div>

            <div>
                <label style="display:block; font-family:var(--font-mono); font-size:0.6875rem; letter-spacing:2px; color:var(--text-muted); text-transform:uppercase; margin-bottom:0.75rem;">Attribuer à</label>
                <div style="display: flex; gap: 1px; background: var(--border); border: 1px solid var(--border); margin-bottom: 1rem;">
                    <label style="flex: 1; display: flex; align-items: center; gap: 0.5rem; padding: 0.5rem 1rem;
                                  cursor: pointer; background: var(--red-faint); color: var(--red);"
                           id="tab-astronaut">
                        <input type="radio" name="target" value="astronaut" checked
                               onchange="toggleTarget(this.value)" style="display:none;">
                        <span style="font-family: var(--font-mono); font-size: 0.6875rem; letter-spacing: 2px;">UN ASTRONAUTE</span>
                    </label>
                    <label style="flex: 1; display: flex; align-items: center; gap: 0.5rem; padding: 0.5rem 1rem;
                                  cursor: pointer; background: var(--panel); color: var(--text-muted);"
                           id="tab-planet">
                        <input type="radio" name="target" value="planet"
                               onchange="toggleTarget(this.value)" style="display:none;">
                        <span style="font-family: var(--font-mono); font-size: 0.6875rem; letter-spacing: 2px;">UNE PLANÈTE</span>
                    </label>
                </div>

                <div id="target-astronaut">
                    <select name="targetId" id="astronaut-select" class="input">
                        <option value="">— Sélectionner un astronaute —</option>
                        {% for astronaut in astronauts %}
                            <option value="{{ astronaut.id }}">
                                {{ astronaut.fullName }}{% if astronaut.planet %} — {{ astronaut.planet.name }}{% endif %}
                            </option>
                        {% endfor %}
                    </select>
                </div>

                <div id="target-planet" style="display: none;">
                    <select name="targetId" id="planet-select" disabled class="input">
                        <option value="">— Sélectionner une planète —</option>
                        {% for planet in planets %}
                            <option value="{{ planet.id }}">{{ planet.name }}</option>
                        {% endfor %}
                    </select>
                </div>
            </div>

            <div style="padding: 0.875rem 1rem; border: 1px solid var(--border);
                        background: var(--panel-raised); border-left: 3px solid var(--amber);">
                <span style="font-family: var(--font-mono); font-size: 0.7rem; color: var(--text-muted); letter-spacing: 1px;">
                    Une notification Slack sera envoyée après attribution (astronaute uniquement).
                </span>
            </div>

        </div>

        <div style="display: flex; gap: 0.75rem;">
            <button type="submit" class="btn btn-primary">ATTRIBUER LE TROPHÉE</button>
            <a href="{{ path('back_trophies_index') }}" class="btn btn-ghost">ANNULER</a>
        </div>
    </form>
</div>

<script>
function toggleTarget(value) {
    const astronautDiv = document.getElementById('target-astronaut');
    const planetDiv = document.getElementById('target-planet');
    const astronautSelect = document.getElementById('astronaut-select');
    const planetSelect = document.getElementById('planet-select');
    const tabA = document.getElementById('tab-astronaut');
    const tabP = document.getElementById('tab-planet');

    if (value === 'astronaut') {
        astronautDiv.style.display = '';
        planetDiv.style.display = 'none';
        astronautSelect.disabled = false;
        planetSelect.disabled = true;
        tabA.style.background = 'var(--red-faint)'; tabA.style.color = 'var(--red)';
        tabP.style.background = 'var(--panel)'; tabP.style.color = 'var(--text-muted)';
    } else {
        astronautDiv.style.display = 'none';
        planetDiv.style.display = '';
        astronautSelect.disabled = true;
        planetSelect.disabled = false;
        tabA.style.background = 'var(--panel)'; tabA.style.color = 'var(--text-muted)';
        tabP.style.background = 'var(--red-faint)'; tabP.style.color = 'var(--red)';
    }
}
</script>
{% endblock %}
