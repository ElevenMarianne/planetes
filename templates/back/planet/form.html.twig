{% extends 'base.html.twig' %}

{% block title %}{{ isEdit ? 'Modifier' : 'Nouvelle' }} planète — Back-office{% endblock %}

{% block body %}
<div style="max-width: 560px; margin: 0 auto;">

    <div style="margin-bottom: 2rem;">
        <div class="header-tags">
            <span class="h-tag red">BACK-OFFICE</span>
            <span class="h-tag">PLANÈTES</span>
        </div>
        <p class="page-title">{{ isEdit ? 'MODIFIER ' ~ planet.name|upper : 'NOUVELLE PLANÈTE' }}</p>
    </div>

    <form method="post" enctype="multipart/form-data" style="display: flex; flex-direction: column; gap: 1.25rem;">

        <div class="card" style="padding: 2rem; display: flex; flex-direction: column; gap: 1.25rem;">

            <div>
                <label style="display:block; font-family:var(--font-mono); font-size:0.6875rem; letter-spacing:2px; color:var(--text-muted); text-transform:uppercase; margin-bottom:0.375rem;">Nom</label>
                <input type="text" name="name" value="{{ planet.name }}" required class="input">
            </div>

            <div>
                <label style="display:block; font-family:var(--font-mono); font-size:0.6875rem; letter-spacing:2px; color:var(--text-muted); text-transform:uppercase; margin-bottom:0.375rem;">Type</label>
                <select name="type" class="input">
                    {% for type in types %}
                        <option value="{{ type.value }}" {{ planet.type is defined and planet.type.value == type.value ? 'selected' : '' }}>
                            {{ type.label() }}
                        </option>
                    {% endfor %}
                </select>
            </div>

            <div>
                <label style="display:block; font-family:var(--font-mono); font-size:0.6875rem; letter-spacing:2px; color:var(--text-muted); text-transform:uppercase; margin-bottom:0.375rem;">Couleur</label>
                <div style="display: flex; align-items: center; gap: 0.875rem;">
                    <input type="color" name="color" value="{{ planet.color }}"
                           style="width: 3rem; height: 2.5rem; border: 1px solid var(--border);
                                  background: transparent; cursor: pointer; padding: 2px;">
                    <span style="font-family: var(--font-mono); font-size: 0.75rem; color: var(--text-muted);">Couleur d'affichage de la planète</span>
                </div>
            </div>

            <div>
                <label style="display:block; font-family:var(--font-mono); font-size:0.6875rem; letter-spacing:2px; color:var(--text-muted); text-transform:uppercase; margin-bottom:0.375rem;">Mantra</label>
                <textarea name="mantra" rows="2" class="input" placeholder="La devise de la planète..." style="resize: vertical;">{{ planet.mantra }}</textarea>
            </div>

            <div>
                <label style="display:block; font-family:var(--font-mono); font-size:0.6875rem; letter-spacing:2px; color:var(--text-muted); text-transform:uppercase; margin-bottom:0.375rem;">Photo / Mascotte</label>
                <div data-controller="photo-preview" style="display: flex; align-items: center; gap: 1rem; margin-top: 0.5rem;">
                    <div class="avatar" style="width: 3.5rem; height: 3.5rem; flex-shrink: 0;">
                        {% if planet.photo %}
                            <img data-photo-preview-target="preview" src="/uploads/{{ planet.photo }}" alt="{{ planet.name }}">
                        {% else %}
                            <img data-photo-preview-target="preview" src="" alt="" style="display: none;">
                            <span style="font-size: 1.375rem;">🪐</span>
                        {% endif %}
                    </div>
                    <div class="file-picker">
                        <button type="button" class="btn-file"
                                data-photo-preview-target="trigger"
                                data-action="click->photo-preview#open">
                            Choisir une image
                        </button>
                        <span class="file-name" data-photo-preview-target="filename">
                            {{ planet.photo ? 'Image actuelle' : 'Aucun fichier' }}
                        </span>
                    </div>
                    <input type="file" name="photo" accept="image/*"
                           data-photo-preview-target="input"
                           data-action="change->photo-preview#preview">
                </div>
            </div>

            <div>
                <label style="display:block; font-family:var(--font-mono); font-size:0.6875rem; letter-spacing:2px; color:var(--text-muted); text-transform:uppercase; margin-bottom:0.375rem;">Artwork / Gundam</label>
                <div data-controller="photo-preview" style="display: flex; align-items: center; gap: 1rem; margin-top: 0.5rem;">
                    <div class="avatar" style="width: 3.5rem; height: 3.5rem; flex-shrink: 0;">
                        {% if planet.artwork %}
                            <img data-photo-preview-target="preview" src="/uploads/{{ planet.artwork }}" alt="{{ planet.name }} artwork">
                        {% else %}
                            <img data-photo-preview-target="preview" src="" alt="" style="display: none;">
                            <span style="font-size: 1.375rem;">🤖</span>
                        {% endif %}
                    </div>
                    <div class="file-picker">
                        <button type="button" class="btn-file"
                                data-photo-preview-target="trigger"
                                data-action="click->photo-preview#open">
                            Choisir une image
                        </button>
                        <span class="file-name" data-photo-preview-target="filename">
                            {{ planet.artwork ? 'Image actuelle' : 'Aucun fichier' }}
                        </span>
                    </div>
                    <input type="file" name="artwork" accept="image/*"
                           data-photo-preview-target="input"
                           data-action="change->photo-preview#preview">
                </div>
            </div>

        </div>

        <div style="display: flex; gap: 0.75rem;">
            <button type="submit" class="btn btn-primary">{{ isEdit ? 'METTRE À JOUR' : 'CRÉER LA PLANÈTE' }}</button>
            <a href="{{ path('back_planets_index') }}" class="btn btn-ghost">ANNULER</a>
        </div>

    </form>
</div>
{% endblock %}
