{% extends 'base.html.twig' %}

{% block title %}Back-office — Eleven Galaxy{% endblock %}

{% block body %}

<div style="display: flex; align-items: flex-end; justify-content: space-between; margin-bottom: 1.5rem;">
    <div>
        <div class="header-tags">
            <span class="h-tag red">ADMINISTRATION</span>
        </div>
        <p class="page-title">BACK-OFFICE</p>
    </div>
</div>

<div class="status-bar" style="margin-bottom: 1.5rem;">
    <div class="status-cell">
        <span class="dot green"></span> SYSTÈME <span class="val">OPÉRATIONNEL</span>
    </div>
    <div class="status-cell">
        ASTRONAUTES <span class="val">{{ astronautCount }}</span>
    </div>
    <div class="status-cell">
        PLANÈTES <span class="val">{{ planetCount }}</span>
    </div>
    <div class="status-cell">
        {% if activeSeason %}
            <span class="dot green"></span> SAISON <span class="val">{{ activeSeason.name|upper }}</span>
        {% else %}
            <span class="dot amber"></span> SAISON <span class="val">INACTIVE</span>
        {% endif %}
    </div>
</div>

{% set links = [
    {label: 'ASTRONAUTES',    sub: 'Gestion des membres',         route: 'back_astronauts_index',     tag: '👨‍🚀'},
    {label: 'PLANÈTES',       sub: 'Équipes en compétition',      route: 'back_planets_index',        tag: '🪐'},
    {label: 'ACTIVITÉS',      sub: 'Attribution de points',       route: 'back_activities_index',     tag: '⚡'},
    {label: 'TYPES ACTIVITÉ', sub: 'Catalogue des actions',       route: 'back_activity_types_index', tag: '📋'},
    {label: 'SAISONS',        sub: 'Périodes de compétition',     route: 'back_seasons_index',        tag: '📅'},
    {label: 'GRADES',         sub: 'Niveaux et seuils',           route: 'back_grades_index',         tag: '⭐'},
    {label: 'TROPHÉES',       sub: 'Récompenses et distinctions', route: 'back_trophies_index',       tag: '🏆'},
    {label: 'ÉVÉNEMENTS',     sub: 'Suivi des présences',         route: 'back_events_index',         tag: '📍'},
] %}

<div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 1px;
            border: 1px solid var(--border); background: var(--border);">
    {% for link in links %}
        <a href="{{ path(link.route) }}"
           style="display: flex; align-items: center; gap: 1.25rem; padding: 1.25rem 1.5rem;
                  background: var(--panel); text-decoration: none; transition: background 0.15s;
                  border-left: 2px solid transparent;"
           onmouseover="this.style.background='var(--panel-raised)'; this.style.borderLeftColor='var(--red)'"
           onmouseout="this.style.background='var(--panel)'; this.style.borderLeftColor='transparent'">
            <span style="font-size: 1.75rem; flex-shrink: 0; line-height: 1; opacity: 0.85;">
                {{ link.tag }}
            </span>
            <div>
                <div style="font-family: var(--font-display); font-size: 0.9375rem; letter-spacing: 3px; color: var(--text);">
                    {{ link.label }}
                </div>
                <div style="font-family: var(--font-mono); font-size: 0.6rem; color: var(--text-subtle);
                             letter-spacing: 2px; margin-top: 3px; text-transform: uppercase;">
                    {{ link.sub }}
                </div>
            </div>
        </a>
    {% endfor %}
</div>

{% endblock %}
