{% extends 'base.html.twig' %}

{% block title %}{{ isEdit ? 'Modifier' : 'Nouveau' }} grade — Back-office{% endblock %}

{% block body %}
<div style="max-width: 480px; margin: 0 auto;">

    <div style="margin-bottom: 2rem;">
        <div class="header-tags">
            <span class="h-tag red">BACK-OFFICE</span>
            <span class="h-tag">GRADES</span>
        </div>
        <p class="page-title">{{ isEdit ? 'MODIFIER ' ~ grade.name|upper : 'NOUVEAU GRADE' }}</p>
    </div>

    <form method="post" style="display: flex; flex-direction: column; gap: 1.25rem;">
        <div class="card" style="padding: 2rem; display: flex; flex-direction: column; gap: 1.25rem;">

            <div>
                <label style="display:block; font-family:var(--font-mono); font-size:0.6875rem; letter-spacing:2px; color:var(--text-muted); text-transform:uppercase; margin-bottom:0.375rem;">Nom</label>
                <input type="text" name="name" value="{{ grade.name }}" required class="input">
            </div>

            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                <div>
                    <label style="display:block; font-family:var(--font-mono); font-size:0.6875rem; letter-spacing:2px; color:var(--text-muted); text-transform:uppercase; margin-bottom:0.375rem;">Points minimum</label>
                    <input type="number" name="minPoints" value="{{ grade.minPoints }}" min="0" required class="input">
                </div>
                <div>
                    <label style="display:block; font-family:var(--font-mono); font-size:0.6875rem; letter-spacing:2px; color:var(--text-muted); text-transform:uppercase; margin-bottom:0.375rem;">Ordre d'affichage</label>
                    <input type="number" name="sortOrder" value="{{ grade.sortOrder }}" min="0" class="input">
                </div>
            </div>

            <div>
                <label style="display:block; font-family:var(--font-mono); font-size:0.6875rem; letter-spacing:2px; color:var(--text-muted); text-transform:uppercase; margin-bottom:0.375rem;">Icône (emoji ou texte)</label>
                <input type="text" name="icon" value="{{ grade.icon }}" placeholder="⭐" class="input">
            </div>

        </div>

        <div style="display: flex; gap: 0.75rem;">
            <button type="submit" class="btn btn-primary">{{ isEdit ? 'METTRE À JOUR' : 'CRÉER LE GRADE' }}</button>
            <a href="{{ path('back_grades_index') }}" class="btn btn-ghost">ANNULER</a>
        </div>
    </form>
</div>
{% endblock %}
