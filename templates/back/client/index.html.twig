{% extends 'base.html.twig' %}

{% block title %}Clients — Back-office{% endblock %}

{% block body %}

<div style="display: flex; align-items: flex-end; justify-content: space-between; margin-bottom: 1.5rem;">
    <div>
        <div class="header-tags">
            <span class="h-tag red">BACK-OFFICE</span>
            <span class="h-tag amber">{{ clients|length }} CLIENT{{ clients|length > 1 ? 'S' : '' }}</span>
        </div>
        <p class="page-title">CLIENTS</p>
    </div>
    <div style="display: flex; gap: 0.75rem;">
        <a href="{{ path('back_dashboard') }}" class="btn btn-ghost btn-sm">← TABLEAU DE BORD</a>
        <a href="{{ path('back_clients_new') }}" class="btn btn-primary btn-sm">+ NOUVEAU</a>
    </div>
</div>

<div class="card" style="overflow: hidden; padding: 0;">
    <table class="back-table">
        <thead>
            <tr>
                <th>Nom</th>
                <th style="text-align: right;">Astronautes</th>
                <th style="text-align: right;">Actions</th>
            </tr>
        </thead>
        <tbody>
            {% for client in clients %}
                <tr>
                    <td style="font-family: var(--font-display); letter-spacing: 2px; color: var(--text);">
                        {{ client.name|upper }}
                    </td>
                    <td style="text-align: right; font-family: var(--font-mono); font-size: 0.75rem; color: var(--text-muted);">
                        {{ client.astronauts|filter(a => a.isActive)|length }}
                    </td>
                    <td style="text-align: right;">
                        <div style="display: flex; gap: 0.5rem; justify-content: flex-end; align-items: center;">
                            <a href="{{ path('back_clients_edit', {id: client.id}) }}" class="btn btn-ghost btn-sm">MODIFIER</a>
                            <form method="post" action="{{ path('back_clients_delete', {id: client.id}) }}" class="inline"
                                  data-controller="confirm-delete"
                                  data-confirm-delete-message-value="Supprimer ce client ? Les astronautes ne seront pas supprimés.">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete_client_' ~ client.id) }}">
                                <button type="submit" class="btn btn-sm"
                                        style="color: var(--red); border-color: var(--red-faint);">SUPPRIMER</button>
                            </form>
                        </div>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="3" style="text-align: center; padding: 3rem; color: var(--text-subtle);">
                        Aucun client.
                    </td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
</div>

{% endblock %}
