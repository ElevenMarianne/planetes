<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Eleven Galaxy{% endblock %}</title>
    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>🪐</text></svg>">
    {% block stylesheets %}{% endblock %}
    {% block javascripts %}
        {% block importmap %}{{ importmap('app') }}{% endblock %}
    {% endblock %}
</head>
<body>

<div class="scanline"></div>

{% if app.user %}
<nav class="nav">
    <div class="nav-logo-section">
        <div class="nav-logo-mark"><div class="inner"></div></div>
        <span class="nav-title">ELEVEN GALAXY</span>
    </div>

    <ul class="nav-links">
        <li><a href="{{ path('front_planets') }}" class="{{ app.request.attributes.get('_route') starts with 'front_planet' ? 'active' : '' }}">Planètes</a></li>
        <li><a href="{{ path('front_astronauts') }}" class="{{ app.request.attributes.get('_route') starts with 'front_astronaut' ? 'active' : '' }}">Astronautes</a></li>
        {% if is_granted('ROLE_ADMIN') %}
            <li><a href="{{ path('back_dashboard') }}">Back-office</a></li>
        {% endif %}
    </ul>

    <div class="nav-system">
        <div class="sys-indicator">
            <span class="sys-dot"></span>
            SYS NOMINAL
        </div>
        <a href="{{ path('front_profile') }}"
           class="sys-user {{ (app.request.attributes.get('_route') starts with 'front_profile' or (app.request.attributes.get('_route') == 'front_astronauts_show' and app.request.attributes.get('id') == app.user.id ~ '')) ? 'active' : '' }}"
           style="text-decoration: none;">OPÉ: {{ app.user.firstName|upper }}</a>
        <a href="{{ path('app_logout') }}" class="nav-logout" title="Se déconnecter">
            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
                <polyline points="16 17 21 12 16 7"/>
                <line x1="21" y1="12" x2="9" y2="12"/>
            </svg>
        </a>
    </div>
</nav>
{% endif %}

<main style="max-width: 1200px; margin: 0 auto; padding: 2rem 1.5rem;">
    {% for flash_type, messages in app.flashes %}
        {% for message in messages %}
            <div class="flash flash-{{ flash_type == 'success' ? 'success' : (flash_type == 'error' ? 'error' : 'info') }}">
                {% if flash_type == 'success' %}✓{% elseif flash_type == 'error' %}✕{% else %}ℹ{% endif %}
                {{ message }}
            </div>
        {% endfor %}
    {% endfor %}

    {% block body %}{% endblock %}
</main>

{% if app.user %}
<div class="footer-bar">
    <div class="footer-item">
        <span class="f-dot green"></span>
        RÉSEAU <span class="f-val">OPÉRATIONNEL</span>
    </div>
    <div class="footer-item">
        SAISON <span class="f-val">ACTIVE</span>
    </div>
    <div class="footer-item">
        PROTOCOLE <span class="f-val">GAMIFICATION v2</span>
    </div>
    <div class="footer-right">ELEVEN LABS — ACCÈS RESTREINT</div>
</div>
{% endif %}

</body>
</html>
