{% extends 'base.html.twig' %}

{% block title %}{{ planet.name }} — Eleven Galaxy{% endblock %}

{% block body %}
<style>
/* ── Variables planète ──────────────────────────────────────────── */
:root {
    --pc:  {{ planet.color }};
    --pc4: {{ planet.color }}44;
    --pc2: {{ planet.color }}22;
    --pc9: {{ planet.color }}99;
}

/* ── Grille hexagonale en fond ──────────────────────────────────── */
.planet-bg {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    overflow: hidden;
}
.planet-bg::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
        linear-gradient(var(--pc2) 1px, transparent 1px),
        linear-gradient(90deg, var(--pc2) 1px, transparent 1px);
    background-size: 48px 48px;
    opacity: 0.35;
    animation: bg-drift 40s linear infinite;
}
.planet-bg::after {
    content: '';
    position: absolute;
    inset: -50%;
    background: radial-gradient(ellipse at 60% 30%, var(--pc2) 0%, transparent 55%);
    animation: bg-pulse 8s ease-in-out infinite;
}
@keyframes bg-drift  { to { background-position: 48px 48px; } }
@keyframes bg-pulse  { 0%,100%{opacity:.6} 50%{opacity:1} }

/* ── Coin brackets réutilisables ────────────────────────────────── */
.hud-panel {
    position: relative;
}
.hud-panel .brk {
    position: absolute;
    width: 14px; height: 14px;
    border-color: var(--pc);
    border-style: solid;
    opacity: .35;
    transition: opacity .3s, width .3s, height .3s;
    pointer-events: none;
    z-index: 2;
}
.hud-panel:hover .brk { opacity: .9; width: 18px; height: 18px; }
.hud-panel .brk.tl { top:4px;    left:4px;    border-width:1px 0 0 1px; }
.hud-panel .brk.tr { top:4px;    right:4px;   border-width:1px 1px 0 0; }
.hud-panel .brk.bl { bottom:4px; left:4px;    border-width:0 0 1px 1px; }
.hud-panel .brk.br { bottom:4px; right:4px;   border-width:0 1px 1px 0; }

/* ── Scan line sur hero ─────────────────────────────────────────── */
.hero-scan {
    position: absolute;
    left: 0; right: 0; height: 1px;
    background: linear-gradient(90deg, transparent, var(--pc), transparent);
    top: 0; pointer-events: none; z-index: 3;
    animation: hero-scan-move 3s linear 0.5s 3;
    opacity: .7;
}
@keyframes hero-scan-move {
    0%   { top: 0%; opacity: .7; }
    95%  { opacity: .7; }
    100% { top: 100%; opacity: 0; }
}

/* ── Photo planète avec reticule ────────────────────────────────── */
.planet-photo-wrap {
    position: relative;
    width: 8rem; height: 8rem;
    flex-shrink: 0;
}
.planet-photo-wrap img,
.planet-photo-wrap .photo-placeholder {
    width: 100%; height: 100%;
    object-fit: contain;
    position: relative; z-index: 1;
    filter: drop-shadow(0 8px 24px var(--pc4));
}
.planet-photo-wrap .photo-placeholder {
    display: flex; align-items: center; justify-content: center;
    background: var(--pc2); border: 1px solid var(--pc4);
    font-size: 3rem;
}
/* Reticule tournant */
.ret-ring {
    position: absolute;
    inset: -10px;
    border: 1px solid var(--pc4);
    border-radius: 50%;
    animation: ret-spin 12s linear infinite;
    pointer-events: none;
}
.ret-ring::before, .ret-ring::after {
    content: '';
    position: absolute;
    background: var(--pc);
    opacity: .6;
}
.ret-ring::before { width: 6px; height: 1px; top: 50%; left: -8px; transform: translateY(-50%); }
.ret-ring::after  { width: 1px; height: 6px; left: 50%; top: -8px; transform: translateX(-50%); }
.ret-ring-2 {
    position: absolute;
    inset: -4px;
    border: 1px solid transparent;
    border-top-color: var(--pc);
    border-bottom-color: var(--pc4);
    border-radius: 50%;
    animation: ret-spin 4s linear infinite reverse;
    pointer-events: none;
}
@keyframes ret-spin { to { transform: rotate(360deg); } }

/* Corner ticks sur la photo */
.ret-corner {
    position: absolute;
    width: 10px; height: 10px;
    border-color: var(--pc);
    border-style: solid;
    opacity: .5;
    z-index: 2;
}
.ret-corner.tl { top: -2px;    left: -2px;    border-width: 2px 0 0 2px; }
.ret-corner.tr { top: -2px;    right: -2px;   border-width: 2px 2px 0 0; }
.ret-corner.bl { bottom: -2px; left: -2px;    border-width: 0 0 2px 2px; }
.ret-corner.br { bottom: -2px; right: -2px;   border-width: 0 2px 2px 0; }

/* ── Compteur points animé ──────────────────────────────────────── */
.pts-counter {
    font-family: var(--font-display);
    font-size: 4rem;
    line-height: 1;
    color: var(--pc);
    text-shadow: 0 0 30px var(--pc4);
    animation: pts-in 0.6s cubic-bezier(0.2,0,0,1) 0.4s both;
}
@keyframes pts-in {
    from { opacity: 0; transform: translateY(12px); filter: blur(4px); }
    to   { opacity: 1; transform: none; filter: none; }
}

/* ── Glitch sur le nom ──────────────────────────────────────────── */
.planet-title-glitch {
    animation: title-glitch 8s ease-in-out infinite;
}
@keyframes title-glitch {
    0%, 88%, 100% { text-shadow: none; transform: none; }
    90% { text-shadow:  3px 0 var(--red), -3px 0 #00e5ff; transform: translateX(-2px); }
    92% { text-shadow: -3px 0 var(--red),  3px 0 #00e5ff; transform: translateX(2px); }
    94% { text-shadow: none; transform: none; }
}

/* ── Sections ───────────────────────────────────────────────────── */
.section-hud {
    border: 1px solid var(--border);
    background: var(--panel);
    position: relative;
    overflow: hidden;
}
.section-hud .stripe-top {
    height: 2px;
    background: linear-gradient(90deg, var(--pc), var(--pc4), transparent 70%);
}

/* ── Row astronaute ─────────────────────────────────────────────── */
.astro-row {
    padding: 0 0.875rem;
    height: 3rem;
    display: flex;
    align-items: center;
    gap: 0.625rem;
    background: var(--panel);
    transition: background 0.15s;
    position: relative;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
}
.astro-row::before {
    content: '';
    position: absolute;
    left: 0; top: 0; bottom: 0;
    width: 0;
    background: var(--pc2);
    transition: width 0.2s;
}
.astro-row:hover::before { width: 100%; }
.astro-row:hover { background: var(--panel-raised); }

/* Signal bars */
.sig-bars {
    display: flex;
    align-items: flex-end;
    gap: 2px;
    flex-shrink: 0;
    height: 19px;
}
.sig-bar {
    width: 3px;
    background: var(--pc);
    opacity: .25;
    border-radius: 1px;
}
.sig-bar.on { opacity: .85; }

/* ── Activity item mecha ────────────────────────────────────────── */
.act-row {
    padding: 0.75rem 1rem;
    background: var(--panel);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    position: relative;
    border-left: 2px solid transparent;
    transition: border-color 0.2s, background 0.15s;
}
.act-row:hover {
    background: var(--panel-raised);
    border-left-color: var(--pc);
}
.act-row::after {
    content: '';
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 1px;
    background: var(--border);
}
.act-row:last-child::after { display: none; }

/* ── Trophée ────────────────────────────────────────────────────── */
.trophy-row {
    padding: 0.75rem 1rem;
    background: var(--panel);
    display: flex;
    align-items: center;
    gap: 0.875rem;
    position: relative;
    overflow: hidden;
    border-left: 2px solid rgba(255,214,0,0.3);
    transition: border-color .2s;
}
.trophy-row:hover { border-left-color: var(--gold); }
.trophy-row::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, rgba(255,214,0,0.03), transparent);
}

/* ── Stagger animations ─────────────────────────────────────────── */
.anim-fade-up          { animation: card-init .4s ease-out both; }
.anim-fade-up.d-1      { animation-delay: .08s; }
.anim-fade-up.d-2      { animation-delay: .16s; }
.anim-fade-up.d-3      { animation-delay: .24s; }
.anim-fade-up.d-4      { animation-delay: .32s; }

/* ── Coord stamp ────────────────────────────────────────────────── */
.coord-stamp {
    font-family: var(--font-mono);
    font-size: .5rem;
    color: var(--text-subtle);
    letter-spacing: 1px;
    opacity: .4;
}
</style>

{# ── Fond animé ───────────────────────────────────────────────── #}
<div class="planet-bg"></div>

{# ── Artwork (Gundam) ─────────────────────────────────────────── #}
{% if planet.artwork %}
<style>
@keyframes gundam-traverse {
    0%   { transform: translateX(calc(100vw - 340px)) translateY(0px)   rotate(3deg); }
    6%   { transform: translateX(calc(100vw - 340px)) translateY(-14px) rotate(1deg); }
    12%  { transform: translateX(calc(100vw - 340px)) translateY(-4px)  rotate(3deg); }
    18%  { transform: translateX(calc(100vw - 340px)) translateY(-10px) rotate(2deg); }
    25%  { transform: translateX(calc(100vw - 340px)) translateY(0px)   rotate(3deg); }
    36%  { transform: translateX(50vw)  translateY(-50px) rotate(-18deg); }
    45%  { transform: translateX(20px)  translateY(0px)   rotate(-4deg); }
    51%  { transform: translateX(20px)  translateY(-14px) rotate(-6deg); }
    57%  { transform: translateX(20px)  translateY(-3px)  rotate(-3deg); }
    63%  { transform: translateX(20px)  translateY(-10px) rotate(-5deg); }
    70%  { transform: translateX(20px)  translateY(0px)   rotate(-4deg); }
    81%  { transform: translateX(50vw)  translateY(-50px) rotate(18deg); }
    90%  { transform: translateX(calc(100vw - 340px)) translateY(-8px) rotate(5deg); }
    100% { transform: translateX(calc(100vw - 340px)) translateY(0px)   rotate(3deg); }
}
@keyframes gundam-glow {
    0%, 100% { opacity: 0.5; transform: scale(1); }
    50%      { opacity: 0.9; transform: scale(1.2); }
}
#planet-gundam-wrap {
    position: fixed; top: 32%; left: 0; z-index: 9000;
    pointer-events: none; user-select: none;
    animation: gundam-traverse 16s cubic-bezier(0.4, 0, 0.2, 1) infinite;
}
#planet-gundam-wrap .glow {
    position: absolute; inset: -25%; border-radius: 50%;
    background: radial-gradient(circle, {{ planet.color }}55 0%, transparent 65%);
    filter: blur(35px);
    animation: gundam-glow 4s ease-in-out infinite;
}
#planet-gundam-wrap img {
    display: block; height: clamp(240px, 26vh, 380px); width: auto;
    object-fit: contain; position: relative;
    filter:
        drop-shadow(0 10px 36px {{ planet.color }}90)
        drop-shadow(0 0 70px {{ planet.color }}45)
        drop-shadow(0 0 3px #fff3);
}
</style>
<div id="planet-gundam-wrap">
    <div class="glow"></div>
    <img src="/uploads/{{ planet.artwork }}" alt="{{ planet.name }}">
</div>
{% endif %}

<div style="max-width: 960px; margin: 0 auto; position: relative; z-index: 1;">

{# ── Breadcrumb HUD ────────────────────────────────────────────── #}
<div style="display: flex; align-items: center; gap: 0.5rem; margin-bottom: 1.25rem; flex-wrap: wrap;">
    <div class="header-tags" style="margin: 0;">
        <span class="h-tag red">DOSSIER PLANÈTE</span>
        <span class="h-tag" style="color: var(--pc); border-color: var(--pc4);">{{ planet.type.value|upper }}</span>
        {% if seasonPoints %}
            <span class="h-tag" style="color: var(--pc); border-color: var(--pc4); display:inline-flex; align-items:center; gap:.4rem;">
                <span style="width:5px;height:5px;border-radius:50%;background:var(--pc);box-shadow:0 0 5px var(--pc);display:inline-block;animation:hud-blink 2s infinite;"></span>
                SAISON ACTIVE
            </span>
        {% endif %}
    </div>
    <span class="coord-stamp" style="margin-left: auto;">{{ planet.id }}N·{{ planet.slug|upper|slice(0,6) }}·SYS</span>
</div>

{# ── Hero panel ────────────────────────────────────────────────── #}
<div class="hud-panel anim-fade-up d-1"
     style="border: 1px solid var(--pc4); background: var(--panel); margin-bottom: 1.5rem; overflow: hidden; position: relative;">

    <div class="brk tl"></div><div class="brk tr"></div>
    <div class="brk bl"></div><div class="brk br"></div>
    <div class="hero-scan"></div>

    {# Stripe top #}
    <div style="height: 3px; background: linear-gradient(90deg, var(--pc), var(--pc4), transparent 70%); position: relative;">
        <div style="position:absolute;right:0;top:0;bottom:0;width:30%;
                    background: repeating-linear-gradient(-45deg, var(--pc2) 0, var(--pc2) 3px, transparent 3px, transparent 8px);"></div>
    </div>

    {# Header bar #}
    <div style="padding: .75rem 1.5rem; display:flex; align-items:center;
                justify-content:space-between; border-bottom:1px solid var(--border);">
        <div style="display:flex; align-items:center; gap:.75rem;">
            <span style="font-family:var(--font-mono);font-size:.6rem;color:var(--text-subtle);letter-spacing:2px;">DOSSIER UNITÉ</span>
            <span style="font-family:var(--font-mono);font-size:.6rem;color:var(--pc);
                         border:1px solid var(--pc4);padding:1px 6px;letter-spacing:2px;
                         animation: hud-blink 3s ease-in-out infinite;">ACTIF</span>
        </div>
        <div style="display:flex; align-items:center; gap:1.25rem;">
            <span style="font-family:var(--font-mono);font-size:.6rem;color:var(--text-subtle);letter-spacing:1px;">
                ID-{{ '%04d'|format(planet.id) }}
            </span>
            <span class="coord-stamp">{{ planet.slug|upper }}</span>
        </div>
    </div>

    <div style="display:flex; align-items:center; gap:2rem; padding:2rem 1.5rem; flex-wrap:wrap;">

        {# Photo + reticule #}
        <div class="planet-photo-wrap">
            {% if planet.photo %}
                <img src="/uploads/{{ planet.photo }}" alt="{{ planet.name }}">
            {% else %}
                <div class="photo-placeholder">🪐</div>
            {% endif %}
            <div class="ret-ring"></div>
            <div class="ret-ring-2"></div>
            <div class="ret-corner tl"></div>
            <div class="ret-corner tr"></div>
            <div class="ret-corner bl"></div>
            <div class="ret-corner br"></div>
        </div>

        <div style="flex:1; min-width:0;">
            <h1 class="planet-title-glitch"
                style="font-family:var(--font-display); font-size:3rem; letter-spacing:6px;
                       color:var(--pc); margin-bottom:.25rem; line-height:1;
                       text-shadow: 0 0 40px var(--pc4);">
                {{ planet.name|upper }}
            </h1>
            {% if planet.mantra %}
                <p style="font-family:var(--font-mono); color:var(--text-muted); font-size:.75rem;
                           letter-spacing:2px; margin-bottom:1rem;">
                    "{{ planet.mantra|upper }}"
                </p>
            {% endif %}

            {# Mini stats #}
            <div style="display:flex; gap:0; border:1px solid var(--border); background:var(--border);
                        width:fit-content; margin-top:.5rem;">
                <div style="background:var(--bg); padding:.4rem .875rem; text-align:center;">
                    <div style="font-family:var(--font-ui); font-size:1.375rem; font-weight:700; color:var(--text); line-height:1;">{{ astronauts|length }}</div>
                    <div style="font-family:var(--font-mono); font-size:.55rem; color:var(--text-muted); letter-spacing:2px; margin-top:2px;">ASTRONAUTES</div>
                </div>
                {% if seasonPoints %}
                <div style="background:var(--bg); padding:.4rem .875rem; text-align:center; border-left:1px solid var(--border);">
                    <div style="font-family:var(--font-ui); font-size:1.375rem; font-weight:700; color:var(--pc); line-height:1;">{{ seasonPoints.totalPoints }}</div>
                    <div style="font-family:var(--font-mono); font-size:.55rem; color:var(--text-muted); letter-spacing:2px; margin-top:2px;">PTS SAISON</div>
                </div>
                {% endif %}
            </div>
        </div>

        {% if seasonPoints %}
        <div style="text-align:right; flex-shrink:0; border-left:1px solid var(--border); padding-left:2rem;">
            <div class="pts-counter" id="pts-counter" data-target="{{ seasonPoints.totalPoints }}">0</div>
            <div style="font-family:var(--font-mono); font-size:.625rem; letter-spacing:3px;
                        color:var(--text-subtle); margin-top:4px;">POINTS SAISON</div>
            {# Jauge verticale #}
            <div style="margin-top:.75rem; display:flex; justify-content:flex-end; gap:2px;">
                {% for i in 1..8 %}
                    <div style="width:4px; height:{{ 6 + i * 3 }}px;
                                background: {% if i <= (seasonPoints.totalPoints / 50)|round %}var(--pc){% else %}var(--border){% endif %};
                                opacity: {% if i <= (seasonPoints.totalPoints / 50)|round %}{% if i == (seasonPoints.totalPoints / 50)|round %}1{% else %}.6{% endif %}{% else %}.25{% endif %};
                                {% if i == (seasonPoints.totalPoints / 50)|round %}box-shadow: 0 0 4px var(--pc);{% endif %}
                                "></div>
                {% endfor %}
            </div>
        </div>
        {% endif %}

    </div>
</div>

{# ── Grid 2 colonnes ─────────────────────────────────────────────── #}
<div style="display:grid; grid-template-columns:1fr 2fr; gap:1.5rem; align-items:start;">

    {# ── Colonne gauche ──────────────────────────────────────────── #}
    <div style="display:flex; flex-direction:column; gap:1.5rem;">

    {# Équipe #}
    <div class="hud-panel section-hud anim-fade-up d-2">
        <div class="brk tl"></div><div class="brk tr"></div>
        <div class="brk bl"></div><div class="brk br"></div>
        <div class="stripe-top"></div>

        <div style="padding:.625rem 1rem; display:flex; align-items:center; justify-content:space-between;
                    border-bottom:1px solid var(--border);">
            <span style="font-family:var(--font-mono); font-size:.6875rem; letter-spacing:3px;
                         color:var(--text-muted);">ASTRONAUTES</span>
            <span style="font-family:var(--font-mono); font-size:.6rem; color:var(--pc);
                         border:1px solid var(--pc4); padding:1px 5px; letter-spacing:1px;">
                {{ astronauts|length }} UNITÉS
            </span>
        </div>

        <div style="display:flex; flex-direction:column; gap:1px; background:var(--border);">
            {% set maxAstroPoints = 0 %}
            {% for a in astronauts %}{% if a.totalPoints > maxAstroPoints %}{% set maxAstroPoints = a.totalPoints %}{% endif %}{% endfor %}
            {% for a in astronauts %}
                {% set sigOn = maxAstroPoints > 0 ? ((a.totalPoints / maxAstroPoints) * 5)|round : 0 %}
                <a href="{{ path('front_astronauts_show', {id: a.id}) }}" class="astro-row">
                    <div class="avatar" style="width:2rem; height:2rem; font-size:.65rem; flex-shrink:0;
                         border-color:var(--pc4); box-shadow:0 0 0 2px var(--pc2);">
                        {% if a.photo %}
                            <img src="/uploads/{{ a.photo }}" alt="">
                        {% else %}
                            {{ a.firstName|first }}{{ a.lastName|first }}
                        {% endif %}
                    </div>
                    <div style="flex:1; min-width:0; position:relative; z-index:1;">
                        <div style="font-size:.875rem; color:var(--text);
                                    white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">{{ a.fullName }}</div>
                    </div>
                    <div style="font-family:var(--font-mono); font-size:.7rem;
                                color:var(--pc); flex-shrink:0; position:relative; z-index:1;">
                        {{ a.totalPoints }}pt
                    </div>
                </a>
            {% else %}
                <div style="padding:1.5rem; text-align:center; background:var(--panel);">
                    <p style="font-family:var(--font-mono); font-size:.7rem; color:var(--text-subtle); letter-spacing:2px;">AUCUN ASTRONAUTE</p>
                </div>
            {% endfor %}
        </div>
    </div>

    {# Trophées #}
    {% if planet.trophies is not empty %}
    <div class="hud-panel section-hud anim-fade-up d-3">
        <div class="brk tl"></div><div class="brk tr"></div>
        <div class="brk bl"></div><div class="brk br"></div>
        <div style="height:2px; background:linear-gradient(90deg, var(--gold), rgba(255,214,0,.2), transparent 70%);"></div>

        <div style="padding:.625rem 1rem; display:flex; align-items:center; justify-content:space-between;
                    border-bottom:1px solid var(--border);">
            <span style="font-family:var(--font-mono); font-size:.6875rem; letter-spacing:3px; color:var(--text-muted);">TROPHÉES</span>
            <span style="font-family:var(--font-mono); font-size:.6rem; color:var(--gold);
                         border:1px solid rgba(255,214,0,.3); padding:1px 5px; letter-spacing:1px;">
                {{ planet.trophies|length }}
            </span>
        </div>

        <div style="display:flex; flex-direction:column; gap:1px; background:var(--border);">
            {% for pt in planet.trophies|sort((a, b) => b.awardedAt <=> a.awardedAt) %}
                <div class="trophy-row">
                    <span style="font-size:1.4rem; line-height:1; flex-shrink:0; position:relative; z-index:1;">🏆</span>
                    <div style="position:relative; z-index:1;">
                        <div style="font-family:var(--font-display); font-size:.8rem; letter-spacing:2px; color:var(--gold);">
                            {{ pt.trophy.name|upper }}
                        </div>
                        {% if pt.season %}
                            <div style="font-family:var(--font-mono); font-size:.6rem; color:var(--text-subtle); letter-spacing:1px; margin-top:2px;">
                                {{ pt.season.name|upper }}
                            </div>
                        {% endif %}
                    </div>
                </div>
            {% endfor %}
        </div>
    </div>
    {% endif %}

    </div>{# fin col gauche #}

    {# ── Activités ────────────────────────────────────────────────── #}
    <div class="hud-panel section-hud anim-fade-up d-3">
        <div class="brk tl"></div><div class="brk tr"></div>
        <div class="brk bl"></div><div class="brk br"></div>
        <div class="stripe-top"></div>

        <div style="padding:.625rem 1rem; display:flex; align-items:center; justify-content:space-between;
                    border-bottom:1px solid var(--border);">
            <span style="font-family:var(--font-mono); font-size:.6875rem; letter-spacing:3px; color:var(--text-muted);">JOURNAL DE MISSIONS</span>
            <span style="font-family:var(--font-mono); font-size:.6rem; color:var(--pc);
                         border:1px solid var(--pc4); padding:1px 5px; letter-spacing:1px;">
                {{ totalActivities }} LOG{{ totalActivities > 1 ? 'S' : '' }}
            </span>
        </div>

        <div style="display:flex; flex-direction:column; background:var(--border); gap:1px;">
            {% for rowIndex, activity in activities %}
                <div class="act-row" style="animation: card-init .3s ease-out {{ 0.04 * rowIndex }}s both;">
                    <span style="font-family:var(--font-mono); font-size:.55rem; color:var(--text-subtle);
                                 letter-spacing:1px; flex-shrink:0; width:2rem; opacity:.5;">
                        {{ '%02d'|format((currentPage - 1) * 10 + rowIndex + 1) }}
                    </span>
                    <div style="flex:1; min-width:0;">
                        <div style="font-family:var(--font-body); font-weight:600; font-size:.9rem; color:var(--text);">
                            {{ activity.type.name }}
                        </div>
                        <div style="font-family:var(--font-mono); font-size:.65rem; color:var(--text-subtle);
                                    letter-spacing:1px; margin-top:.125rem;">
                            {{ activity.astronauts|map(a => a.fullName)|join(' · ') }}
                            <span style="opacity:.5; margin:0 .25rem;">—</span>
                            {{ activity.createdAt|date('d/m/Y') }}
                        </div>
                    </div>
                    <div style="font-family:var(--font-mono); font-size:.8rem; font-weight:700;
                                color:var(--pc); flex-shrink:0; text-shadow: 0 0 8px var(--pc4);">
                        +{{ activity.points }}pt
                    </div>
                </div>
            {% else %}
                <div style="padding:2.5rem; text-align:center; background:var(--panel);">
                    <p style="font-family:var(--font-mono); font-size:.7rem; color:var(--text-subtle); letter-spacing:2px;">AUCUNE ACTIVITÉ CETTE SAISON</p>
                </div>
            {% endfor %}
        </div>

        {# Pagination #}
        {% if totalPages > 1 %}
        <div style="display:flex; align-items:center; justify-content:space-between;
                    padding:.625rem 1rem; border-top:1px solid var(--border); background:var(--panel);">
            <span style="font-family:var(--font-mono); font-size:.6rem; color:var(--text-subtle); letter-spacing:1px;">
                PAGE {{ currentPage }}/{{ totalPages }}
            </span>
            <div style="display:flex; gap:1px; background:var(--border);">
                {% if currentPage > 1 %}
                    <a href="{{ path('front_planets_show', {slug: planet.slug, page: currentPage - 1}) }}"
                       style="padding:.3rem .75rem; font-family:var(--font-mono); font-size:.6875rem;
                              letter-spacing:1px; background:var(--panel); color:var(--text-muted);
                              text-decoration:none; transition:background .15s;"
                       onmouseover="this.style.background='var(--panel-raised)'"
                       onmouseout="this.style.background='var(--panel)'">← PRÉC</a>
                {% endif %}
                {% for p in 1..totalPages %}
                    <a href="{{ path('front_planets_show', {slug: planet.slug, page: p}) }}"
                       style="padding:.3rem .625rem; font-family:var(--font-mono); font-size:.6875rem;
                              letter-spacing:1px; text-decoration:none; transition:background .15s;
                              {% if p == currentPage %}
                                  background:var(--pc2); color:var(--pc); border:1px solid var(--pc4); margin:-1px;
                              {% else %}
                                  background:var(--panel); color:var(--text-subtle);
                              {% endif %}">{{ p }}</a>
                {% endfor %}
                {% if currentPage < totalPages %}
                    <a href="{{ path('front_planets_show', {slug: planet.slug, page: currentPage + 1}) }}"
                       style="padding:.3rem .75rem; font-family:var(--font-mono); font-size:.6875rem;
                              letter-spacing:1px; background:var(--panel); color:var(--text-muted);
                              text-decoration:none; transition:background .15s;"
                       onmouseover="this.style.background='var(--panel-raised)'"
                       onmouseout="this.style.background='var(--panel)'">SUIV →</a>
                {% endif %}
            </div>
        </div>
        {% endif %}
    </div>

</div>{# fin grid #}
</div>{# fin max-width #}

<script>
(function () {
    // Compteur animé pour les points
    const el = document.getElementById('pts-counter');
    if (!el) return;
    const target = parseInt(el.dataset.target, 10) || 0;
    const duration = 900;
    const start = performance.now();
    function tick(now) {
        const t = Math.min((now - start) / duration, 1);
        const ease = 1 - Math.pow(1 - t, 3);
        el.textContent = Math.round(ease * target);
        if (t < 1) requestAnimationFrame(tick);
    }
    setTimeout(() => requestAnimationFrame(tick), 400);
})();
</script>

{% endblock %}
