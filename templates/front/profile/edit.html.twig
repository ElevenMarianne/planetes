{% extends 'base.html.twig' %}

{% block title %}Mon profil — Eleven Galaxy{% endblock %}

{% block body %}
<div style="max-width: 560px; margin: 0 auto;">

    <div style="margin-bottom: 2rem;">
        <p class="page-title">Mon profil</p>
    </div>

    {{ form_start(form, {attr: {enctype: 'multipart/form-data', style: 'display: flex; flex-direction: column; gap: 1.25rem;'}}) }}

        <div class="card" style="padding: 2rem; display: flex; flex-direction: column; gap: 1.25rem;">

            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                <div>
                    {{ form_label(form.firstName) }}
                    {{ form_widget(form.firstName, {attr: {class: 'input'}}) }}
                    {{ form_errors(form.firstName) }}
                </div>
                <div>
                    {{ form_label(form.lastName) }}
                    {{ form_widget(form.lastName, {attr: {class: 'input'}}) }}
                    {{ form_errors(form.lastName) }}
                </div>
            </div>

            <div>
                {{ form_label(form.client) }}

                {# Select caché — binding Symfony #}
                {{ form_widget(form.client, {attr: {style: 'display:none'}}) }}

                {# Widget visible : texte + suggestions #}
                <div style="position: relative;">
                    <input type="text" id="client-search"
                           autocomplete="off" spellcheck="false"
                           class="input"
                           placeholder="Rechercher ou créer un client…"
                           value="{{ astronaut.client ? astronaut.client.name : '' }}"
                           style="width: 100%;">
                    <ul id="client-suggestions"
                        style="display:none; position:absolute; top:100%; left:0; right:0; z-index:200;
                               background:var(--panel-raised); border:1px solid var(--border);
                               border-top:none; list-style:none; margin:0; padding:0; max-height:220px; overflow-y:auto;">
                    </ul>
                </div>
                <p id="client-status"
                   style="display:none; font-family:var(--font-mono); font-size:0.65rem;
                          letter-spacing:1px; margin-top:0.25rem;"></p>
            </div>

            <script>
            (function () {
                const CLIENTS   = {{ clients|json_encode|raw }};
                const QUICK_URL = {{ path('back_clients_quick_create')|json_encode|raw }};

                const searchInput = document.getElementById('client-search');
                const suggestions = document.getElementById('client-suggestions');
                const statusEl    = document.getElementById('client-status');
                const select      = document.getElementById('{{ form.client.vars.id }}');

                let activeIndex = -1;

                function normalize(s) { return s.toLowerCase().trim(); }

                function render(query) {
                    const q = normalize(query);
                    suggestions.innerHTML = '';
                    activeIndex = -1;

                    if (q === '') { hide(); return; }

                    const matches = CLIENTS.filter(c => normalize(c.name).includes(q));

                    matches.forEach(c => {
                        const li = document.createElement('li');
                        li.dataset.id   = c.id;
                        li.dataset.name = c.name;
                        li.textContent  = c.name;
                        li.style.cssText = 'padding:0.5rem 0.875rem; cursor:pointer; font-family:var(--font-mono); font-size:0.8rem; letter-spacing:1px;';
                        li.addEventListener('mousedown', e => { e.preventDefault(); pick(c.id, c.name); });
                        li.addEventListener('mouseover', () => setActive(Array.from(suggestions.children).indexOf(li)));
                        suggestions.appendChild(li);
                    });

                    const exactMatch = CLIENTS.some(c => normalize(c.name) === q);
                    if (!exactMatch) {
                        const li = document.createElement('li');
                        li.dataset.create = '1';
                        li.dataset.name   = query.trim();
                        li.innerHTML = `<span style="color:var(--red);">+ Créer</span> « ${query.trim()} »`;
                        li.style.cssText = 'padding:0.5rem 0.875rem; cursor:pointer; font-family:var(--font-mono); font-size:0.8rem; letter-spacing:1px; border-top:1px solid var(--border);';
                        li.addEventListener('mousedown', e => { e.preventDefault(); createAndPick(query.trim()); });
                        li.addEventListener('mouseover', () => setActive(Array.from(suggestions.children).indexOf(li)));
                        suggestions.appendChild(li);
                    }

                    suggestions.style.display = suggestions.children.length ? '' : 'none';
                }

                function setActive(idx) {
                    const items = Array.from(suggestions.children);
                    items.forEach((li, i) => {
                        li.style.background = i === idx ? 'var(--panel)' : '';
                    });
                    activeIndex = idx;
                }

                function pick(id, name) {
                    select.value       = id;
                    searchInput.value  = name;
                    setStatus(name, false);
                    hide();
                }

                function setStatus(name, isNew) {
                    statusEl.textContent    = isNew ? `✓ Client « ${name} » créé et sélectionné.` : `✓ ${name}`;
                    statusEl.style.color    = 'var(--green-bright)';
                    statusEl.style.display  = 'block';
                }

                function hide() { suggestions.style.display = 'none'; }

                async function createAndPick(name) {
                    searchInput.disabled = true;
                    statusEl.textContent = '…';
                    statusEl.style.color = 'var(--text-muted)';
                    statusEl.style.display = 'block';
                    hide();

                    try {
                        const fd = new FormData();
                        fd.append('name', name);
                        const res  = await fetch(QUICK_URL, { method: 'POST', body: fd });
                        const data = await res.json();

                        if (!res.ok) {
                            statusEl.textContent = data.error ?? 'Erreur.';
                            statusEl.style.color = 'var(--red)';
                            return;
                        }

                        // Ajouter au select si absent
                        if (!select.querySelector(`option[value="${data.id}"]`)) {
                            select.appendChild(new Option(data.name, data.id));
                            CLIENTS.push({ id: data.id, name: data.name });
                        }
                        pick(data.id, data.name);
                        setStatus(data.name, true);
                    } catch {
                        statusEl.textContent = 'Erreur réseau.';
                        statusEl.style.color = 'var(--red)';
                    } finally {
                        searchInput.disabled = false;
                    }
                }

                searchInput.addEventListener('input', () => render(searchInput.value));

                searchInput.addEventListener('keydown', e => {
                    const items = Array.from(suggestions.children);
                    if (e.key === 'ArrowDown') {
                        e.preventDefault();
                        setActive(Math.min(activeIndex + 1, items.length - 1));
                    } else if (e.key === 'ArrowUp') {
                        e.preventDefault();
                        setActive(Math.max(activeIndex - 1, 0));
                    } else if (e.key === 'Enter' && activeIndex >= 0) {
                        e.preventDefault();
                        items[activeIndex]?.dispatchEvent(new MouseEvent('mousedown'));
                    } else if (e.key === 'Escape') {
                        hide();
                    }
                });

                searchInput.addEventListener('focus', () => { if (searchInput.value) render(searchInput.value); });
                document.addEventListener('click', e => { if (!e.target.closest('#client-search, #client-suggestions')) hide(); });

                // Si le champ est vidé → désélectionner
                searchInput.addEventListener('change', () => {
                    if (searchInput.value.trim() === '') {
                        select.value = '';
                        statusEl.style.display = 'none';
                    }
                });
            })();
            </script>

            <div>
                {{ form_label(form.hobbies) }}
                {{ form_widget(form.hobbies, {attr: {class: 'input', style: 'min-height: 100px; resize: vertical;'}}) }}
            </div>

            <div>
                {{ form_label(form.squad) }}
                {{ form_widget(form.squad, {attr: {class: 'input'}}) }}
            </div>

            <div>
                {{ form_label(form.photoFile) }}
                <div data-controller="photo-preview" style="display: flex; align-items: center; gap: 1rem; margin-top: 0.5rem;">
                    <div class="avatar" style="width: 3.5rem; height: 3.5rem; font-size: 1rem; flex-shrink: 0;">
                        {% if astronaut.photo %}
                            <img data-photo-preview-target="preview" src="/uploads/{{ astronaut.photo }}" alt="Photo">
                        {% else %}
                            <img data-photo-preview-target="preview" src="" alt="" style="display: none;">
                            <span>{{ astronaut.firstName|first }}{{ astronaut.lastName|first }}</span>
                        {% endif %}
                    </div>
                    <div class="file-picker">
                        <button type="button" class="btn-file"
                                data-photo-preview-target="trigger"
                                data-action="click->photo-preview#open">
                            📷 Choisir une photo
                        </button>
                        <span class="file-name" data-photo-preview-target="filename">
                            {% if astronaut.photo %}Photo actuelle{% else %}Aucun fichier{% endif %}
                        </span>
                    </div>
                    {{ form_widget(form.photoFile, {attr: {
                        'data-photo-preview-target': 'input',
                        'data-action': 'change->photo-preview#preview',
                        'accept': 'image/*'
                    }}) }}
                </div>
            </div>

        </div>

        <button type="submit" class="btn btn-primary" style="padding: 0.875rem; font-size: 1rem; border-radius: var(--r);">
            Enregistrer
        </button>

    {{ form_end(form) }}
</div>
{% endblock %}
