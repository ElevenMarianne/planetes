{% extends 'base.html.twig' %}

{% block title %}Classement — Eleven Galaxy{% endblock %}

{% block body %}
<div style="max-width: 800px; margin: 0 auto;">

    <div class="page-header" style="padding: 0 0 0; margin-bottom: 0;">
        <div>
            <div class="header-tags">
                <span class="h-tag red">RAPPORT DE MISSION</span>
                {% if season %}
                    <span class="h-tag amber">{{ season.name|upper }}</span>
                {% endif %}
            </div>
            <p class="page-title">CLASSEMENT</p>
        </div>
        {% if season %}
        <div class="header-meta">
            <div>DÉBUT <span class="val">{{ season.startDate|date('d/m/Y') }}</span></div>
            <div>FIN <span class="val">{{ season.endDate|date('d/m/Y') }}</span></div>
        </div>
        {% endif %}
    </div>

    {% if season %}
    <div class="status-bar" style="margin: 14px 0 24px;">
        <div class="status-cell">
            <span class="dot green"></span>
            COMPÉTITION <span class="val">ACTIVE</span>
        </div>
        <div class="status-cell">
            SAISON <span class="val">{{ season.name|upper }}</span>
        </div>
        <div class="status-cell">
            {{ season.startDate|date('d/m/Y') }} → {{ season.endDate|date('d/m/Y') }}
        </div>
    </div>
    {% else %}
    <div style="margin: 14px 0 24px;">
        <div class="status-bar">
            <div class="status-cell">
                <span class="dot amber"></span>
                COMPÉTITION <span class="val">EN ATTENTE</span>
            </div>
        </div>
    </div>
    {% endif %}

    {% if leaderboard %}
        <div style="display: flex; flex-direction: column; gap: 1px; border: 1px solid var(--border); background: var(--border);">
            {% for index, psp in leaderboard %}
                {% set rankClass = index == 0 ? 'rank-1' : (index == 1 ? 'rank-2' : (index == 2 ? 'rank-3' : (index == 3 ? 'rank-4' : 'rank-n'))) %}
                <a href="{{ path('front_planets_show', {slug: psp.planet.slug}) }}"
                   class="lb-row anim-fade-up"
                   style="--planet-color: {{ psp.planet.color }};
                          display: flex; align-items: center; gap: 1rem;
                          padding: 0.875rem 1.25rem;
                          background: var(--panel);
                          border-left: 2px solid {% if index == 0 %}var(--gold){% elseif index == 1 %}var(--silver){% elseif index == 2 %}var(--bronze){% else %}var(--border){% endif %};
                          transition: background 0.15s;
                          animation: card-init 0.4s ease-out both;
                          animation-delay: {{ index * 0.06 }}s;"
                   onmouseover="this.style.background='var(--panel-raised)'"
                   onmouseout="this.style.background='var(--panel)'">

                    {# Rang #}
                    <div style="width: 2.5rem; text-align: center; flex-shrink: 0;">
                        {% if index == 0 %}
                            <span style="font-size: 1.375rem; line-height: 1;">🥇</span>
                        {% elseif index == 1 %}
                            <span style="font-size: 1.375rem; line-height: 1;">🥈</span>
                        {% elseif index == 2 %}
                            <span style="font-size: 1.375rem; line-height: 1;">🥉</span>
                        {% else %}
                            <span style="font-family: var(--font-display); font-size: 1.5rem; color: var(--text-muted); line-height: 1;">{{ index + 1 }}</span>
                        {% endif %}
                    </div>

                    {# Mascotte #}
                    {% if psp.planet.photo %}
                        <img src="/uploads/{{ psp.planet.photo }}" alt="{{ psp.planet.name }}"
                             style="width: 2.75rem; height: 2.75rem; object-fit: contain; flex-shrink: 0;
                                    filter: drop-shadow(0 2px 8px {{ psp.planet.color }}60);">
                    {% else %}
                        <div style="width: 2.75rem; height: 2.75rem; background: {{ psp.planet.color }}22;
                                    border: 1px solid {{ psp.planet.color }}44; flex-shrink: 0; display: flex;
                                    align-items: center; justify-content: center; font-size: 1.25rem;">🪐</div>
                    {% endif %}

                    {# Nom + mantra #}
                    <div style="flex: 1; min-width: 0;">
                        <div style="font-family: var(--font-display); font-size: 1.125rem; letter-spacing: 3px;
                                    color: {{ psp.planet.color }}; line-height: 1.1;
                                    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                            {{ psp.planet.name|upper }}
                        </div>
                        {% if psp.planet.mantra %}
                            <div style="font-family: var(--font-mono); font-size: 0.6875rem; color: var(--text-subtle);
                                        letter-spacing: 1px; margin-top: 2px;
                                        white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                                {{ psp.planet.mantra|upper }}
                            </div>
                        {% endif %}
                    </div>

                    {# Points #}
                    <div style="text-align: right; flex-shrink: 0; border-left: 1px solid var(--border); padding-left: 1.25rem;">
                        <div style="font-family: var(--font-display); font-size: 1.75rem; line-height: 1;
                                    color: {% if index == 0 %}var(--gold){% elseif index == 1 %}var(--silver){% elseif index == 2 %}var(--bronze){% else %}var(--text){% endif %};">
                            {{ psp.totalPoints }}
                        </div>
                        <div style="font-family: var(--font-mono); font-size: 0.625rem; letter-spacing: 2px;
                                    color: var(--text-muted); margin-top: 2px;">POINTS</div>
                    </div>

                </a>
            {% endfor %}
        </div>
    {% else %}
        <div class="card" style="padding: 3rem; text-align: center;">
            <div style="font-family: var(--font-mono); font-size: 0.75rem; color: var(--text-subtle); letter-spacing: 3px; margin-bottom: 1rem;">
                AUCUNE DONNÉE DISPONIBLE
            </div>
            <p style="color: var(--text-muted); font-family: var(--font-body);">Aucun score pour cette saison.</p>
        </div>
    {% endif %}

</div>
{% endblock %}
