{% extends 'base.html.twig' %}

{% block title %}Connexion — Eleven Galaxy{% endblock %}

{% block body %}
<canvas id="login-stars"></canvas>

<div class="login-scene">

    <div class="solar-system anim-scale-in">
        <div class="sun-wrap">
            <div class="sun-glow2"></div>
            <div class="sun-glow"></div>
            <canvas id="sunCanvas" width="200" height="200"></canvas>
            <div class="cross-flare"><span class="cf-h"></span><span class="cf-v"></span></div>
        </div>

        <div class="orbit orbit-1">
            <div class="planet-wrap"><div class="planet p-red"></div></div>
        </div>
        <div class="orbit orbit-2">
            <div class="planet-wrap"><div class="planet p-yellow"></div></div>
        </div>
        <div class="orbit orbit-3">
            <div class="planet-wrap"><div class="planet p-green"></div></div>
        </div>
        <div class="orbit orbit-4">
            <div class="planet-wrap">
                <div class="planet p-blue"></div>
                <div class="saturn-ring"></div>
            </div>
        </div>
    </div>

    <div class="login-card anim-fade-up d-2">
        <p class="login-title">Eleven Galaxy</p>
        <p class="login-sub">La gamification interne d'Eleven Labs</p>

        {% if error %}
            <div class="flash flash-error" style="margin-bottom: 1.5rem; text-align: left;">✕ {{ error }}</div>
        {% endif %}

        <a href="{{ path('connect_google') }}" class="btn-google">
            <svg width="20" height="20" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
                <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
                <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
            </svg>
            Se connecter avec Google
        </a>

        <p class="login-note">Réservé aux membres @eleven-labs.com</p>
    </div>

</div>

<script>
/* ─── STARS ─── */
(function () {
    const cv = document.getElementById('login-stars');
    const ctx = cv.getContext('2d');
    let stars = [];

    function resize() {
        cv.width  = innerWidth;
        cv.height = innerHeight;
        stars = Array.from({ length: 280 }, () => ({
            x:  Math.random() * cv.width,
            y:  Math.random() * cv.height,
            r:  Math.random() * 1.2 + 0.2,
            a:  Math.random() * 0.5 + 0.1,
            sp: Math.random() * 0.002 + 0.0005,
            ph: Math.random() * 6.28,
        }));
    }

    function draw(t) {
        ctx.clearRect(0, 0, cv.width, cv.height);
        stars.forEach(s => {
            const f = 0.5 + 0.5 * Math.sin(t * s.sp * 500 + s.ph);
            ctx.beginPath();
            ctx.arc(s.x, s.y, s.r, 0, 6.28);
            ctx.fillStyle = `rgba(255,255,255,${s.a * f})`;
            ctx.fill();
        });
        requestAnimationFrame(draw);
    }

    addEventListener('resize', resize);
    resize();
    requestAnimationFrame(draw);
})();

/* ─── SUN (anime cel-shaded) ─── */
(function () {
    const cv  = document.getElementById('sunCanvas');
    const ctx = cv.getContext('2d');
    const SW = cv.width, SH = cv.height;
    const CX = SW / 2, CY = SH / 2, SR = 82;

    function draw(time) {
        const t = time * 0.00006;
        ctx.clearRect(0, 0, SW, SH);

        /* Corona rays */
        ctx.save();
        ctx.translate(CX, CY);
        ctx.rotate(t * 0.4);
        const rayCount = 14;
        for (let i = 0; i < rayCount; i++) {
            const angle = (i / rayCount) * Math.PI * 2;
            const pulse = 0.6 + 0.4 * Math.sin(t * 2 + i * 1.5);
            ctx.save();
            ctx.rotate(angle);
            ctx.beginPath();
            ctx.moveTo(-4, -SR * 0.9);
            ctx.lineTo(0, -SR * 1.35 * pulse);
            ctx.lineTo(4, -SR * 0.9);
            ctx.closePath();
            ctx.fillStyle = `rgba(255,200,80,${0.07 * pulse})`;
            ctx.fill();
            ctx.restore();
        }
        ctx.restore();

        /* Light source drift */
        const lx = Math.cos(t * 0.25) * 0.3;
        const ly = Math.sin(t * 0.25) * 0.3;

        /* Cel-shaded bands */
        [
            { r: 1.0,  c: '#8a2200' },
            { r: 0.93, c: '#b83800' },
            { r: 0.84, c: '#d45000' },
            { r: 0.73, c: '#f07800' },
            { r: 0.60, c: '#ff9d2e' },
            { r: 0.45, c: '#ffbe40' },
            { r: 0.27, c: '#ffe8a0' },
        ].forEach(b => {
            ctx.beginPath();
            ctx.arc(CX + lx * b.r * 22, CY + ly * b.r * 22, SR * b.r, 0, Math.PI * 2);
            ctx.fillStyle = b.c;
            ctx.fill();
        });

        /* Surface convection arcs */
        ctx.save();
        ctx.translate(CX, CY);
        ctx.rotate(t * 0.15);
        ctx.beginPath();
        ctx.arc(0, 0, SR - 2, 0, Math.PI * 2);
        ctx.clip();
        for (let i = 0; i < 6; i++) {
            const a  = (i / 6) * Math.PI * 2 + t * 0.3;
            const r  = SR * (0.5 + 0.2 * Math.sin(t * 0.5 + i * 1.8));
            const x1 = Math.cos(a) * r, y1 = Math.sin(a) * r;
            const x2 = Math.cos(a + 0.5) * r * 0.85, y2 = Math.sin(a + 0.5) * r * 0.85;
            ctx.beginPath();
            ctx.moveTo(x1, y1);
            ctx.quadraticCurveTo(
                (x1 + x2) / 2 + Math.sin(t * 0.4 + i) * 12,
                (y1 + y2) / 2 + Math.cos(t * 0.4 + i) * 12,
                x2, y2
            );
            ctx.strokeStyle = `rgba(140,40,0,${0.15 + 0.08 * Math.sin(t + i)})`;
            ctx.lineWidth = 2;
            ctx.stroke();
        }
        ctx.restore();

        /* Specular highlights */
        const sX = CX - SR * 0.25 + lx * 15;
        const sY = CY - SR * 0.25 + ly * 15;
        ctx.beginPath();
        ctx.ellipse(sX, sY, SR * 0.17, SR * 0.11, -0.5, 0, Math.PI * 2);
        ctx.fillStyle = 'rgba(255,255,240,0.5)';
        ctx.fill();
        ctx.beginPath();
        ctx.ellipse(sX + SR * 0.12, sY + SR * 0.16, SR * 0.055, SR * 0.035, -0.3, 0, Math.PI * 2);
        ctx.fillStyle = 'rgba(255,255,255,0.35)';
        ctx.fill();

        /* Black outline */
        ctx.beginPath();
        ctx.arc(CX, CY, SR, 0, Math.PI * 2);
        ctx.strokeStyle = 'rgba(0,0,0,0.85)';
        ctx.lineWidth = 3;
        ctx.stroke();

        /* Eruption flares */
        ctx.save();
        ctx.translate(CX, CY);
        for (let i = 0; i < 3; i++) {
            const fa    = t * 0.5 + i * 2.2;
            const pulse = 0.4 + 0.6 * Math.sin(t * 1.2 + i * 3.5);
            const fx    = Math.cos(fa) * SR;
            const fy    = Math.sin(fa) * SR;
            const fLen  = 7 + pulse * 14;
            ctx.beginPath();
            ctx.moveTo(fx * 0.96, fy * 0.96);
            ctx.lineTo(fx + Math.cos(fa) * fLen + Math.sin(fa) * 4, fy + Math.sin(fa) * fLen - Math.cos(fa) * 4);
            ctx.lineTo(fx + Math.cos(fa) * fLen * 0.5 - Math.sin(fa) * 4, fy + Math.sin(fa) * fLen * 0.5 + Math.cos(fa) * 4);
            ctx.closePath();
            ctx.fillStyle = `rgba(255,${140 + pulse * 80},0,${0.3 * pulse})`;
            ctx.fill();
            ctx.strokeStyle = `rgba(0,0,0,${0.25 * pulse})`;
            ctx.lineWidth = 1.5;
            ctx.stroke();
        }
        ctx.restore();

        requestAnimationFrame(draw);
    }

    requestAnimationFrame(draw);
})();
</script>
{% endblock %}
